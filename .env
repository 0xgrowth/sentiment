# =============================================================================
# Crypto Sentiment Tracker — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# NEVER commit .env to version control.
# .env is already listed in .gitignore.
#
# Variable reference: app/config.py (Settings class)
# =============================================================================


# ── Application ───────────────────────────────────────────────────────────────

# Runtime environment. Controls logging verbosity and debug features.
# Options: development | staging | production
ENVIRONMENT=development

# Enable FastAPI debug mode (auto-reload, detailed error pages).
# Set to false in staging/production.
DEBUG=true

# Logging level. Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── API Server ────────────────────────────────────────────────────────────────

# Interface to bind. Use 0.0.0.0 to accept connections from all interfaces.
HOST=0.0.0.0

# Port to listen on.
PORT=8000

# Number of Uvicorn worker processes.
# For production with multiple cores: set to (2 × CPU cores) + 1
WORKERS=1

# Auto-reload on code changes. Set to false in production.
RELOAD=true


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# Default covers Vite dev server (5173) and CRA (3000).
# In production replace with your deployed frontend URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Database ──────────────────────────────────────────────────────────────────

# Async SQLAlchemy connection URL.
#
# Development (SQLite — zero setup):
DATABASE_URL=sqlite+aiosqlite:///./crypto_sentiment.db
#
# Production (PostgreSQL — recommended):
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/crypto_sentiment
#
# PostgreSQL via Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@db:5432/crypto_sentiment

# Echo all SQL statements to stdout. Useful for debugging queries.
# Set to false in production.
DB_ECHO=false

# SQLAlchemy connection pool settings (relevant for PostgreSQL).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10


# ── Anthropic / Claude AI ─────────────────────────────────────────────────────

# Required. Your Anthropic API key.
# Get one at: https://console.anthropic.com
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Claude model used for sentiment analysis and alert narratives.
# Recommended: claude-sonnet-4-20250514 (best balance of speed + quality)
# Faster/cheaper: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximum tokens in Claude's response per request.
ANTHROPIC_MAX_TOKENS=1024

# HTTP timeout (seconds) for Anthropic API calls.
ANTHROPIC_TIMEOUT=30.0


# ── Market Data (yfinance) ────────────────────────────────────────────────────

# How many minutes a fetched market snapshot is considered fresh.
# Requests within this window return the cached DB value without hitting yfinance.
MARKET_CACHE_TTL_MINUTES=5

# Comma-separated list of crypto symbols refreshed on every scheduler tick.
# Must match keys in CRYPTO_TICKER_MAP in markets_router.py.
DEFAULT_SYMBOLS=BTC,ETH,SOL,BNB,XRP


# ── APScheduler ───────────────────────────────────────────────────────────────

# How often (minutes) the markets scheduler fetches fresh OHLCV data.
MARKETS_REFRESH_INTERVAL_MINUTES=5

# How often (minutes) the analysis scheduler re-runs Claude sentiment.
# Keep higher than markets interval to manage Anthropic API costs.
ANALYSIS_REFRESH_INTERVAL_MINUTES=15

# How often (minutes) the alerts scheduler evaluates all active rules.
ALERTS_EVAL_INTERVAL_MINUTES=5

# Timezone for all scheduler jobs. Use IANA timezone names.
SCHEDULER_TIMEZONE=UTC

# Seconds a job is allowed to run late before being skipped.
SCHEDULER_MISFIRE_GRACE_SECONDS=30


# ── Security ──────────────────────────────────────────────────────────────────

# Secret key for signing tokens / session cookies.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
# CHANGE THIS before deploying to any public environment.
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Optional: protect all API endpoints with a static API key.
# If set, every request must include: X-API-Key: <value>
# Leave blank to disable API key authentication.
INTERNAL_API_KEY=

# Header name used for the API key check above.
API_KEY_HEADER=X-API-Key


# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Enable request rate limiting (requires slowapi — uncomment in requirements.txt).
RATE_LIMIT_ENABLED=false

# Max requests per minute per IP across all endpoints.
RATE_LIMIT_PER_MINUTE=60

# Max Claude/sentiment calls per hour (these cost money — protect them).
RATE_LIMIT_SENTIMENT_PER_HOUR=100


# ── PostgreSQL (if using Docker Compose) ─────────────────────────────────────
# These are only needed if you run the provided docker-compose.yml.
# They are NOT read by the app directly — DATABASE_URL above takes precedence.

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=yourpassword
# POSTGRES_DB=crypto_sentiment
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
